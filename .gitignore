# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.superpowers
.worktrees

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# history
.history

# tauri desktop packaging
/src-tauri/target/
/src-tauri/resources/app/
/src-tauri/resources/node/
/src-tauri/resources/package.json
/src-tauri/resources/package-lock.json

# local runtime cache
/.desktop-runtimes/
/.desktop-native/
/.tmp-node/
